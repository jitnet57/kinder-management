# Production Environment Variables
# Used by Vercel Deployment

# API Configuration
# For Vercel deployment, adjust endpoint as needed
VITE_API_URL=https://kinder-management.vercel.app/api
VITE_API_TIMEOUT=30000

# Feature Flags (all enabled in production)
VITE_ENABLE_BACKUP=true
VITE_ENABLE_REPORTS=true
VITE_ENABLE_ENCRYPTION=true

# Build Configuration
VITE_BUILD_TIME=production
