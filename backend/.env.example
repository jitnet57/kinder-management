# Backend Environment Variables
# Copy this file to .env and fill in the actual values

# Server Configuration
PORT=3000
NODE_ENV=development
HOST=localhost

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/aba_child_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aba_child_db
DB_USER=postgres
DB_PASSWORD=

# Backup & Encryption
BACKUP_ENCRYPTION=true
BACKUP_PASSWORD=
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# API Configuration
API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173,https://aba-child.pages.dev

# Security
JWT_SECRET=
SESSION_SECRET=

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50000000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
